datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --------------------------------------
// Enums
// --------------------------------------

enum Gender {
  MALE
  FEMALE
}

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  ACCOUNTANT // New Role
  ASSISTANT
  TEACHER
  STUDENT
}

enum Status {
  ACTIVE
  PENDING
  EXPIRED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum ExpenseType {
  SALARY
  MAINTENANCE
  SUPPLIES
  RENT
  UTILITIES
  MARKETING
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentType {
  TUITION
  TRANSPORT
  BOOKS
  UNIFORM
  ACTIVITIES
  OTHER
}

enum ExamType {
  // النصف الأول - First Semester
  OCTOBER
  NOVEMBER
  DECEMBER
  FIRST_SEMESTER_AVG // محسوبة تلقائياً

  //  نصف السنة - Midyear
  MIDYEAR

  // النصف الثاني - Second Semester
  MARCH
  APRIL
  SECOND_SEMESTER_AVG // محسوبة تلقائياً

  // المحصلة النهائية - Final Results
  ANNUAL_EFFORT // السعي السنوي (محسوب)
  FINAL_EXAM // الامتحان النهائي
  FINAL_GRADE // الدرجة النهائية (محسوبة)

  // الدور الثاني - Second Round
  SECOND_ROUND_EXAM // امتحان الدور الثاني (للراسبين فقط)
  LAST_GRADE // الدرجة الأخيرة (محسوبة)
}

// --------------------------------------
// Core Models
// --------------------------------------

model User {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  studentCode String?
  email       String   @unique
  phone     String?
  password  String
  image     String?  // Profile picture URL (stored in Supabase)
  gender    Gender
  birthDate DateTime
  role      Role     @default(SCHOOL_ADMIN)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  // --- Relations ---

  // 1. School Membership
  schoolId String?
  school   School? @relation("SchoolMembers", fields: [schoolId], references: [id], onDelete: Cascade)

  // 2. School Ownership
  ownedSchool School? @relation("SchoolOwner")

  // 3. Academic (Student)
  classId String?
  class   Class?  @relation("ClassStudents", fields: [classId], references: [id])

  // 4. Academic (Teacher)
  subjects Subject[] @relation("TeacherSubjects")
  notes    Note[]    @relation("TeacherNotes")
  schedules Schedule[]

  // 5. Financial (Student)
  paymentsMade Payment[] @relation("StudentPayments")

  // 6. Financial (Staff/Accountant)
  transactionsRecorded Payment[] @relation("PaymentRecorder")
  expensesRecorded     Expense[] @relation("ExpenseRecorder")
  salariesReceived     Expense[] @relation("ExpenseRecipient")

  // 7. Attendance
  attendanceRecords Attendance[] @relation("UserAttendance")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 8. Academic Results
  gradesAsStudent Grade[] @relation("StudentGrades")
  gradesAsTeacher Grade[] @relation("TeacherGrades")

  // 9. Student Profile (Financial/Academic Details)
  studentProfile StudentProfile?

  // 10. Notifications
  notifications Notification[] @relation("UserNotifications")

  @@index([email])
  @@index([role])
  @@index([schoolId])
  @@unique([schoolId, studentCode])
}

model School {
  id      String  @id @default(uuid())
  name    String  @unique
  slug    String  @unique
  logo    String?
  address String?
  phone   String?

  // Owner
  ownerId String @unique
  owner   User   @relation("SchoolOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Members
  members User[] @relation("SchoolMembers")

  // Plan & Subscription
  subscription Subscription?

  // Academic Structure
  classes Class[]
  schedules Schedule[]

  // Financial Records
  payments Payment[]
  expenses Expense[]
  feeStructures FeeStructure[]

  // Attendance Records
  attendanceRecords Attendance[]

  // Academic Years
  academicYears AcademicYear[]

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  subscriptionRequests SubscriptionRequest[]
}

// --------------------------------------
// Subscription & Plans
// --------------------------------------

model Plan {
  id                   String                @id @default(uuid())
  name                 String                @unique
  description          String?
  price                Float                 @default(0)
  maxStudents          Int                   @default(15)
  bufferStudents       Int                   @default(10)
  pricePerExtraStudent Float                 @default(9)
  
  hasBasicManagement   Boolean               @default(true)
  hasAttendance        Boolean               @default(true)
  hasSchedules         Boolean               @default(false)
  hasExcelUpload       Boolean               @default(false)
  hasFinancials        Boolean               @default(false)
  hasBusSystem         Boolean               @default(false)
  hasMobileApp         Boolean               @default(false)
  hasAiReports         Boolean               @default(false)
  
  supportLevel         String                @default("EMAIL")
  
  maxTeachers          Int                   @default(10)
  allowReports         Boolean               @default(false)
  storageLimit         Int                   @default(100)
  durationInDays       Int                   @default(365)
  subscriptions        Subscription[]
  createdAt            DateTime              @default(now())
  subscriptionRequests SubscriptionRequest[]
}

model Subscription {
  id          String   @id @default(uuid())
  schoolId    String   @unique
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  startDate   DateTime @default(now())
  endDate     DateTime
  status      Status   @default(PENDING)
  currentDebt Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --------------------------------------
// Subscription Request
// --------------------------------------

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model SubscriptionRequest {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status RequestStatus @default(PENDING)

  adminNotes     String?
  paymentReceipt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String // e.g. "2024-2025"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  grades Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isCurrent])
}

// --------------------------------------
// Academic Structure
// --------------------------------------

model Class {
  id   String @id @default(uuid())
  name String // e.g. "1st Grade"

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  students User[]    @relation("ClassStudents")
  subjects Subject[]
  notes    Note[]
  schedules Schedule[]

  tuitionFee Float @default(0) // Fee for this class
  feeStructures FeeStructure[]

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FeeStructure {
  id     String @id @default(uuid())
  amount Float

  // Keep requested name "gradeId", and map it to existing Class model.
  gradeId String
  grade   Class  @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, gradeId])
  @@index([schoolId])
  @@index([gradeId])
}

model Subject {
  id   String @id @default(uuid())
  name String // e.g. "Mathematics"

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   User?   @relation("TeacherSubjects", fields: [teacherId], references: [id])

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  grades    Grade[]
  schedules Schedule[]

  @@index([classId])
  @@index([teacherId])
}

model Note {
  id      String @id @default(uuid())
  content String // The announcement

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation("TeacherNotes", fields: [teacherId], references: [id])

  createdAt DateTime @default(now())
}

// --------------------------------------
// Financial Module
// --------------------------------------

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  date          DateTime      @default(now())
  note          String? // e.g. "1st Installment"
  status        PaymentStatus @default(PENDING)
  paymentType   PaymentType   @default(TUITION)
  invoiceNumber String?       @unique

  studentId String
  student   User   @relation("StudentPayments", fields: [studentId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  recordedById String?
  recordedBy   User?   @relation("PaymentRecorder", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([date])
}

model Expense {
  id     String      @id @default(uuid())
  title  String // e.g. "Teacher Salary"
  amount Float
  type   ExpenseType
  date   DateTime    @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  recipientId String? // If salary
  recipient   User?   @relation("ExpenseRecipient", fields: [recipientId], references: [id])

  recipientName String? // Manual name if not a school member

  recordedById String?
  recordedBy   User?   @relation("ExpenseRecorder", fields: [recordedById], references: [id])

  isDeleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([type])
  @@index([date])
}

// --------------------------------------
// Attendance Module
// --------------------------------------

model Attendance {
  id     String           @id @default(uuid())
  date   DateTime         @default(now())
  status AttendanceStatus
  reason String?

  userId String
  user   User   @relation("UserAttendance", fields: [userId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // Optional linkage to Class for easier querying (if student)
  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, schoolId])
  @@index([schoolId])
  @@index([date])
}

// --------------------------------------
// Grades Module
// --------------------------------------

model Grade {
  id           String   @id @default(uuid())
  score        Float?   // الدرجة (اختيارية لدعم المؤجلين)
  notes        String?  // اختياري لكتابة (غائب، مؤجل، إلخ)
  examType     ExamType // نوع الامتحان
  isCalculated Boolean  @default(false) // هل الدرجة محسوبة تلقائياً؟

  studentId String
  student   User   @relation("StudentGrades", fields: [studentId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   User   @relation("TeacherGrades", fields: [teacherId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // منع تكرار نفس الدرجة لنفس الطالب/المادة/السنة/نوع الامتحان
  @@unique([studentId, subjectId, academicYearId, examType])
  @@index([studentId])
  @@index([subjectId])
  @@index([academicYearId])
  @@index([examType])
}

// --------------------------------------
// Student Profile (Clean Architecture)
// --------------------------------------

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  discountAmount Float   @default(0)
  discountNotes  String?

  customTuitionFee Float? // Override for class tuitionFee

  motherName             String?
  guardianMaritalStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// --------------------------------------
// Schedule Module
// --------------------------------------

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Schedule {
  id        String   @id @default(uuid())
  day       DayOfWeek
  startTime String   // e.g. "08:00"
  endTime   String   // e.g. "08:45"
  
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@index([day])
}

// --------------------------------------
// Notification Module
// --------------------------------------

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // e.g., "SUBSCRIPTION_REQUEST", "SYSTEM", "SUBSCRIPTION_UPDATE"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// --------------------------------------
// Platform Management (Super Admin)
// --------------------------------------

model PlatformReport {
  id              String   @id @default(uuid())
  title           String
  year            Int
  month           Int?
  type            String   // e.g., "MONTHLY", "ANNUAL"
  totalRevenue    Float
  schoolsCount    Int
  pendingRequests Int
  details         Json     // Full snapshot data
  createdAt       DateTime @default(now())

  @@index([year, month])
  @@index([type])
}

model ContactMessage {
  id           String   @id @default(uuid())
  name         String
  schoolName   String   @map("school_name")
  phone        String
  email        String
  studentCount String   @map("student_count")
  message      String?  @db.Text
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_messages")
}
